{
    "name": "courses-frontend",
    "license": "(MIT OR Apache-2.0)",
    "private": true,
    "version": "0.0.0",
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "tsc -b && vite build",
        "preview": "vite preview",
        "check:ci": "biome check --no-errors-on-unmatched --files-ignore-unknown=true",
        "check": "bun run check:ci -- --write --unsafe",
        "preinstall": "npx only-allow bun",
        "prepare": "husky"
    },
    "commitlint": {
        "extends": [
            "@commitlint/config-conventional"
        ]
    },
    "lint-staged": {
        "*": [
            "bun run check"
        ]
    },
    "dependencies": {
        "@tailwindcss/vite": "^4.1.11",
        "@tanstack/react-router": "^1.125.6",
        "@tanstack/react-router-devtools": "^1.125.6",
        "react": "^19.1.0",
        "react-dom": "^19.1.0",
        "tailwindcss": "^4.1.11"
    },
    "devDependencies": {
        "@biomejs/biome": "^2.1.0",
        "@commitlint/cli": "^19.8.1",
        "@commitlint/config-conventional": "^19.8.1",
        "@tanstack/router-plugin": "^1.125.6",
        "@types/react": "^19.1.8",
        "@types/react-dom": "^19.1.6",
        "@vitejs/plugin-react-oxc": "^0.2.3",
        "husky": "^9.1.7",
        "lint-staged": "^16.1.2",
        "typescript": "~5.8.3",
        "vite": "npm:rolldown-vite@latest"
    }
}
